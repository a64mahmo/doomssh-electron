{
  "name": "doomssh",
  "version": "1.2.2",
  "private": true,
  "main": "electron/dist/main.js",
  "build": {
    "appId": "com.doomssh.app",
    "productName": "DoomSSH",
    "publish": [
      {
        "provider": "github",
        "owner": "a64mahmo",
        "repo": "doomssh-electron"
      }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "frontend/out/**/*",
      "electron/dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "dotenv": "^16.0.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/electron": "^1.6.10",
    "@types/node": "^20",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run electron:watch\" \"npm run electron:dev\"",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:install": "cd frontend && npm install",
    "install-all": "npm install && npm run frontend:install",
    "build": "cd frontend && npm run build",
    "electron:build": "tsc -p electron/tsconfig.json",
    "electron:watch": "tsc -p electron/tsconfig.json --watch",
    "electron:dev": "wait-on electron/dist/main.js && NODE_ENV=development electron electron/dist/main.js",
    "electron:preview": "npm run build && npm run electron:build && NODE_ENV=production electron electron/dist/main.js",
    "electron:dist": "npm run build && npm run electron:build && electron-builder",
    "dev:all": "npm run dev",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual",
    "test:performance": "playwright test tests/performance",
    "test:regression": "playwright test tests/regression",
    "test:integration": "playwright test tests/integration",
    "test:all": "npm run test --prefix frontend && npm run test:e2e && npm run test:visual && npm run test:performance && npm run test:regression && npm run test:integration"
  }
}
