{
  "name": "doomssh",
  "version": "0.1.1",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd frontend && npm run start",
    "frontend:install": "cd frontend && npm install",
    "electron:build": "tsc -p electron/tsconfig.json",
    "electron:dev": "NODE_ENV=development electron electron/dist/main.js",
    "electron:dist": "npm run build && npm run electron:build && electron-builder",
    "dev:all": "npm run dev",
    "test:e2e": "playwright test",
    "test:all": "npm run test --prefix frontend && npm run test:e2e"
  },
  "build": {
    "appId": "com.doomssh.app",
    "productName": "DoomSSH",
    "publish": [
      {
        "provider": "github",
        "owner": "a64mahmo",
        "repo": "doomssh-electron"
      }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "frontend/.next/**/*",
      "frontend/public/**/*",
      "frontend/package.json",
      "frontend/next.config.ts",
      "electron/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "dotenv": "^16.0.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/electron": "^1.6.10",
    "@types/node": "^20",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
